# ============================================
# Variables de entorno para StockPlus Backend (Express.js)
# Copiar a backend/.env y ajustar valores
# ============================================

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=TU_CONTRASEÑA_AQUI
PG_DB=stockplus

# JWT
JWT_SECRET_KEY=stockplus-secret-production-key-cambiar-en-produccion-2024

# Servidor
PORT=5000
NODE_ENV=development

# CORS (separar por coma los orígenes permitidos, vacío = todos en desarrollo)
# CORS_ORIGINS=http://localhost,http://localhost:5173
